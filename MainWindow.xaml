<Window x:Class="HY_TWEAK.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="HY TWEAK - Premium System Optimizer" Height="800" Width="1200"
        Background="#0F1419" Foreground="#FFFFFF"
        WindowStyle="None" AllowsTransparency="True"
        MouseDown="Window_MouseDown">
    <Grid>
        <!-- Header -->
        <StackPanel VerticalAlignment="Top" Height="60" Background="#1A1F2E">
            <TextBlock Text="HY TWEAK - Premium System Optimizer" FontSize="24" FontWeight="Bold" Margin="20,15,0,0" Foreground="#00D9FF"/>
        </StackPanel>

        <!-- Main Content -->
        <TabControl Margin="0,60,0,0" Background="#0F1419" Foreground="#FFFFFF">
            <TabItem Header="System Info" Background="#1A1F2E" Foreground="#FFFFFF">
                <Grid Background="#0F1419" Padding="20">
                    <StackPanel>
                        <TextBlock Name="SystemInfoText" FontSize="14" TextWrapping="Wrap" Foreground="#00D9FF"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="GPU Tweaks" Background="#1A1F2E" Foreground="#FFFFFF">
                <Grid Background="#0F1419" Padding="20">
                    <StackPanel Name="GPUTweaksPanel"/>
                </Grid>
            </TabItem>

            <TabItem Header="CPU Tweaks" Background="#1A1F2E" Foreground="#FFFFFF">
                <Grid Background="#0F1419" Padding="20">
                    <StackPanel Name="CPUTweaksPanel"/>
                </Grid>
            </TabItem>

            <TabItem Header="Fortnite Boost" Background="#1A1F2E" Foreground="#FFFFFF">
                <Grid Background="#0F1419" Padding="20">
                    <StackPanel Name="FortnitePanel"/>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- Footer -->
        <StackPanel VerticalAlignment="Bottom" Height="50" Background="#1A1F2E" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Name="ApplyButton" Content="Apply Tweaks" Width="150" Height="40" Margin="10" Background="#00D9FF" Foreground="#000000" Click="ApplyButton_Click"/>
            <Button Name="ResetButton" Content="Reset" Width="100" Height="40" Margin="10" Background="#FF6B6B" Foreground="#FFFFFF" Click="ResetButton_Click"/>
        </StackPanel>
    </Grid>
</Window>