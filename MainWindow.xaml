<Window x:Class="HY_TWEAK.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="HY TWEAK" Height="600" Width="800" Background="#1E1E1E">
    <Window.Resources>
        <LinearGradientBrush x:Key="BackgroundBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#00A86B" Offset="0.0" />
            <GradientStop Color="#005A30" Offset="1.0" />
        </LinearGradientBrush>
    </Window.Resources>

    <Grid Background="{StaticResource BackgroundBrush}">
        <TabControl>
            <TabItem Header="System Info">
                <!-- System Information UI -->
            </TabItem>
            <TabItem Header="GPU Tweaks">
                <!-- GPU Tweaks UI -->
            </TabItem>
            <TabItem Header="CPU Tweaks">
                <!-- CPU Tweaks UI -->
            </TabItem>
            <TabItem Header="Fortnite Boost">
                <!-- Fortnite Boost UI -->
            </TabItem>
        </TabControl>
        <Button Content="Apply Tweaks" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="10" Height="40" Width="120" Background="#00A86B" />
    </Grid>
</Window>